<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:layout_marginBottom="4dp"
    android:gravity="center_vertical"
    android:background="@color/surface_dark">

    <!-- SZÍNSÁV : Az esemény típusát jelző színes csík (Narancs: Esés, Piros: Ütés) -->
    <View
        android:id="@+id/eventColorBar"
        android:layout_width="4dp"
        android:layout_height="40dp"
        android:background="@color/freefall_color" />

    <!-- IKON : Szimbolikus jelzés (nyíl vagy felkiáltójel) -->
    <TextView
        android:id="@+id/eventIcon"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:gravity="center"
        android:textSize="18sp"
        android:layout_marginStart="12dp" />

    <!-- SZÖVEGES TARTALOM : Esemény megnevezése és pontos ideje -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/eventType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="@color/text_primary" />

        <TextView
            android:id="@+id/eventTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- ÉRTÉK KIJELZÉSE : A méréskor rögzített legnagyobb/legkisebb gyorsulás -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/eventSpeed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="m/s²"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="2dp" />
    </LinearLayout>

</LinearLayout>
