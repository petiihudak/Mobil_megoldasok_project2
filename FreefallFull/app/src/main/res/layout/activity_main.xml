<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark"
    android:padding="0dp">

    <!-- FELSŐ FEJLÉC : Alkalmazás neve és az aktív/szünet állapot jelzése -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/surface_dark"
        android:padding="16dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ESÉS DETEKTOR"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:fontFamily="monospace" />

        <!-- Állapotjelző pötty : Színe változik az állapottól függően (Zöld/Sárga) -->
        <View
            android:id="@+id/statusDot"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:background="@drawable/dot_active" />

        <!-- Állapotjelző felirat : AKTÍV vagy SZÜNET felirat megjelenítése -->
        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AKTÍV"
            android:textColor="@color/accent_green"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <!-- GYORSULÁS KIJELZŐ : A mért eredő gyorsulás (m/s²) és a tengelyenkénti adatok -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_dark"
        android:padding="24dp"
        android:gravity="center"
        android:layout_marginTop="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GYORSULÁS"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:fontFamily="monospace" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <!-- Fő érték kijelzése : Nagy digitális számok a pillanatnyi gyorsuláshoz -->
            <TextView
                android:id="@+id/speedValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0.00"
                android:textColor="@color/text_primary"
                android:textSize="64sp"
                android:textStyle="bold"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" m/s²"
                android:textColor="@color/text_secondary"
                android:textSize="20sp"
                android:fontFamily="monospace"
                android:layout_marginBottom="8dp" />
        </LinearLayout>

        <!-- G-erő Progress Bar : Vizuális skála a gyorsulás mértékéhez -->
        <ProgressBar
            android:id="@+id/gforceBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="8dp"
            android:max="200"
            android:progress="98"
            android:progressDrawable="@drawable/progress_bar_drawable"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0 m/s²"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace" />

            <!-- Pillanatnyi G érték : A gravitációs állandóhoz viszonyított arány -->
            <TextView
                android:id="@+id/gforceLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1.0 G"
                android:textColor="@color/accent_green"
                android:textSize="11sp"
                android:fontFamily="monospace" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="20 m/s²"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:gravity="end" />
        </LinearLayout>

        <!-- TENGELYEK SZERINTI BONTÁS : X, Y, Z nyers adatok megjelenítése -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:background="@color/background_dark"
            android:padding="12dp">

            <!-- X Tengely -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="X"
                    android:textColor="@color/axis_x"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/axisX"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Y Tengely -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Y"
                    android:textColor="@color/axis_y"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/axisY"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />
            </LinearLayout>

            <!-- Z Tengely -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Z"
                    android:textColor="@color/axis_z"
                    android:textSize="10sp"
                    android:fontFamily="monospace" />
                <TextView
                    android:id="@+id/axisZ"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:fontFamily="monospace" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- ESEMÉNYEK LISTÁJA : Detektált esések és becsapódások naplója -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:layout_marginTop="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ESEMÉNYEK"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:letterSpacing="0.2"
            android:fontFamily="monospace" />

        <!-- TÖRLÉS gomb : A naplózott események kiürítése a listából -->
        <TextView
            android:id="@+id/clearButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TÖRLÉS"
            android:textColor="@color/text_secondary"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:padding="4dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>

    <!-- RecyclerView : Itt jelennek meg görgethetően a rögzített adatok -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/eventsList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

    <!-- ÉRZÉKENYSÉG VEZÉRLÉS : Csúszka a fizikai küszöbértékek állításához -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/surface_dark"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="ÉRZÉKENYSÉG"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="monospace" />

            <!-- Aktuális szint neve (ALACSONY/NORMÁL/MAGAS) -->
            <TextView
                android:id="@+id/sensitivityLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="NORMÁL"
                android:textColor="@color/accent_green"
                android:textSize="10sp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- SeekBar : Csúszka az érzékenység állításához -->
        <SeekBar
            android:id="@+id/sensitivityBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="2"
            android:progress="1"
            android:layout_marginTop="8dp"
            android:progressTint="@color/accent_green"
            android:thumbTint="@color/accent_green" />
    </LinearLayout>

    <!-- ALSÓ NAVIGÁCIÓ : Váltás a Detektor és az Érmedobás képernyők között -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        app:itemIconTint="@color/accent_green"
        app:itemTextColor="@color/text_primary"
        app:menu="@menu/nav_menu" />

</LinearLayout>
